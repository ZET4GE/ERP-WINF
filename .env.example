# Supabase — obtené estos valores en Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron (Fase 8) — string aleatorio largo
CRON_SECRET=

# Recordatorios WhatsApp (Fase 12) — dejar todo vacío desactiva el envío
# (el cron sigue corriendo y registra los recordatorios como "sin_configurar",
# sin romper nada). Elegir un proveedor y completar solo sus variables:
WHATSAPP_PROVIDER=
WHATSAPP_REMINDER_DAYS_BEFORE=3

# Meta WhatsApp Cloud API (WHATSAPP_PROVIDER=meta)
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=

# WATI (WHATSAPP_PROVIDER=wati)
WATI_API_ENDPOINT=
WATI_API_KEY=

# Twilio WhatsApp API (WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
